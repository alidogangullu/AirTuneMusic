# Apple Music API — Developer token (do not commit real values)
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Team ID (10 chars) — from developer.apple.com/account → Membership
APPLE_TEAM_ID=

# Key ID (10 chars) — from your Media key in Certificates, Identifiers & Profiles
APPLE_KEY_ID=

# Either the path to your .p8 file (recommended)…
APPLE_PRIVATE_KEY_PATH=

# …or the full key content (use if you can't use a file path).
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
# MIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...
# -----END PRIVATE KEY-----"

# Token for the app (from: npm run token:apple-music). Used by Expo via app.config.js.
# Later you can switch to fetching the token from your backend.
EXPO_PUBLIC_APPLE_MUSIC_TOKEN=
